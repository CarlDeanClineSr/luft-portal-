name: JWST Science Pipeline
on:
  push:
    branches: [ main ]
  workflow_dispatch:

permissions:
  contents: write  # Critical: Allows the workflow to push commits back to the repo

jobs:
  run-pipeline:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
        with:
          persist-credentials: true # Required for pushing changes

      - name: Set up Python 3.12
        uses: actions/setup-python@v4
        with:
          python-version: '3.12'

      - name: Cache pip dependencies
        uses: actions/cache@v3
        with:
          path: ~/.cache/pip
          key: ${{ runner.os }}-pip-${{ hashFiles('requirements.txt') }}
          restore-keys: |
            ${{ runner.os }}-pip-

      - name: Install dependencies
        run: |
          pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run Pipeline (Automated)
        run: |
          python scripts/fetch_mast.py
          python scripts/process_calibration.py
          python scripts/analyze_transit.py

      - name: Archive Results
        run: |
          git config --global user.name 'github-actions[bot]'
          git config --global user.email 'github-actions[bot]@users.noreply.github.com'
          # Only add if there are actual changes to prevent unnecessary commits
          git add output/
          if ! git diff --cached --quiet; then
            git commit -m "Auto-archive: Science pipeline artifacts [skip ci]"
            git push
          else
            echo "No new artifacts to archive."
          fi
